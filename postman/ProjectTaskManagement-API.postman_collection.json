{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-project-task-api",
    "name": "Project & Task Management API",
    "description": "Backend .NET Developer Technical Assessment — .NET 9 Clean Architecture API.\n\n## Setup\n1. Import this collection into Postman\n2. Ensure `baseUrl` = `http://localhost:5000` (or your Docker host)\n3. Run **Auth → Login (Demo User)** — token is saved automatically\n4. Run other requests\n\n## Demo credentials\n- User: user@projecttask.com / User@123\n- Admin: admin@projecttask.com / Admin@123",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "apiVersion", "value": "v1" },
    { "key": "token", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "projectId", "value": "" },
    { "key": "taskId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        },
        {
          "name": "Health Ready",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health/ready"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newuser@test.com\",\n  \"password\": \"Password123\",\n  \"fullName\": \"New User\"\n}"
            },
            "url": "{{baseUrl}}/api/{{apiVersion}}/auth/register"
          }
        },
        {
          "name": "Login (Demo User)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data && res.data.token) {",
                  "    pm.collectionVariables.set('token', res.data.token);",
                  "    console.log('User token saved to collection variable: token');",
                  "}",
                  "pm.test('Login successful', () => pm.response.to.have.status(200));",
                  "pm.test('Token received', () => pm.expect(res.data.token).to.be.a('string').and.not.empty);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@projecttask.com\",\n  \"password\": \"User@123\"\n}"
            },
            "url": "{{baseUrl}}/api/{{apiVersion}}/auth/login"
          }
        },
        {
          "name": "Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data && res.data.token) {",
                  "    pm.collectionVariables.set('adminToken', res.data.token);",
                  "    console.log('Admin token saved to collection variable: adminToken');",
                  "}",
                  "pm.test('Admin login successful', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@projecttask.com\",\n  \"password\": \"Admin@123\"\n}"
            },
            "url": "{{baseUrl}}/api/{{apiVersion}}/auth/login"
          }
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "Create Project",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data && res.data.id) {",
                  "    pm.collectionVariables.set('projectId', res.data.id);",
                  "}",
                  "pm.test('Project created', () => pm.response.to.have.status(201));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Assessment Demo Project\",\n  \"description\": \"Created via Postman collection\"\n}"
            },
            "url": "{{baseUrl}}/api/{{apiVersion}}/projects"
          }
        },
        {
          "name": "Get All Projects",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/projects?pageNumber=1&pageSize=10&search=",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "projects"],
              "query": [
                { "key": "pageNumber", "value": "1" },
                { "key": "pageSize", "value": "10" },
                { "key": "search", "value": "" }
              ]
            }
          }
        },
        {
          "name": "Get Project By Id",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/{{apiVersion}}/projects/{{projectId}}"
          }
        },
        {
          "name": "Update Project",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Project Name\",\n  \"description\": \"Updated via Postman\"\n}"
            },
            "url": "{{baseUrl}}/api/{{apiVersion}}/projects/{{projectId}}"
          }
        },
        {
          "name": "Delete Project",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/api/{{apiVersion}}/projects/{{projectId}}"
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Create Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data && res.data.id) {",
                  "    pm.collectionVariables.set('taskId', res.data.id);",
                  "}",
                  "pm.test('Task created', () => pm.response.to.have.status(201));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"projectId\": \"{{projectId}}\",\n  \"title\": \"Implement API endpoint\",\n  \"description\": \"Build and test via Postman\",\n  \"dueDate\": \"2026-12-31T00:00:00Z\",\n  \"priority\": 2\n}"
            },
            "url": "{{baseUrl}}/api/{{apiVersion}}/tasks"
          }
        },
        {
          "name": "Get Tasks By Project",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/tasks/project/{{projectId}}?pageNumber=1&pageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "tasks", "project", "{{projectId}}"],
              "query": [
                { "key": "pageNumber", "value": "1" },
                { "key": "pageSize", "value": "20" },
                { "key": "status", "value": "0", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Update Task Status",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": 1\n}"
            },
            "url": "{{baseUrl}}/api/{{apiVersion}}/tasks/{{taskId}}/status",
            "description": "Status: 0=Todo, 1=InProgress, 2=Done, 3=Cancelled"
          }
        },
        {
          "name": "Delete Task",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/api/{{apiVersion}}/tasks/{{taskId}}"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Get Admin Stats",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/{{apiVersion}}/admin/stats",
            "description": "Requires Admin role. Run Auth → Login (Admin) first."
          }
        }
      ]
    }
  ]
}
